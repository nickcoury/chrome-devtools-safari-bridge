{
  "name": "chrome-devtools-safari-bridge",
  "private": true,
  "version": "0.0.1",
  "description": "Use Chrome DevTools to debug Safari — desktop, iOS simulator, and real iPhone.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "start": "node ./scripts/launch.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "verify": "node ./scripts/verify-desktop.mjs",
    "kill": "lsof -iTCP:9221 -iTCP:9333 -P -t 2>/dev/null | xargs kill -9 2>/dev/null; echo 'Killed stale bridge processes'",
    "build:ext": "bash ./scripts/build-extension.sh",
    "test": "node test/differential/runner.mjs",
    "test:parity": "node test/differential/runner.mjs",
    "test:panels": "node test/verify-panels.mjs",
    "test:cdp": "node test/verify-cdp.mjs",
    "test:screenshots": "node test/screenshot-all-panels.mjs"
  },
  "dependencies": {
    "@appium/strongbox": "^1.0.2",
    "@jridgewell/trace-mapping": "^0.3.31",
    "appium-ios-device": "^3.1.10",
    "express": "^4.21.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "puppeteer": "^24.40.0"
  }
}
