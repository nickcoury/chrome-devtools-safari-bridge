{
  "manifest_version": 2,
  "name": "DevTools Safari Bridge",
  "version": "1.0",
  "description": "Connects Chrome DevTools to Safari pages for debugging",
  "permissions": [
    "activeTab",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
